#multi-threaded processes

#ppp
win_parent_process2_mt_ppp.test: $(OBJDIR)grand_parent_tool$(PINTOOL_SUFFIX) $(OBJDIR)parent_tool$(PINTOOL_SUFFIX) $(OBJDIR)follow_child_3gen_tool$(PINTOOL_SUFFIX) $(OBJDIR)win_parent_process_mt$(EXE_SUFFIX) $(OBJDIR)win_child_process$(EXE_SUFFIX) $(GRAND_PARENT_TOOL_CROSS_32)
	$(RM) -f $(OBJDIR)win_parent_process2_mt_ppp.out
	$(CMD) win_parent_process_mt_test_launcher_w_pintool_args.bat "$(PIN)" "$(PIN_TESTFLAGS) \
	  $(PINFLAGS) -follow_execv -probe $(GRAND_PARENT_TOOL_CROSS_64_KNOB) $(GRAND_PARENT_TOOL_CROSS_32_KNOB) \
	  -probe_child 1 -probe_grand_child 1 -pin_path \"$(INJ_ROOT)/\" -tools_path \"$(TOOLS_PATH)\"" "$(OBJDIR)" \
	    > $(OBJDIR)win_parent_process2_mt_ppp.out 2>&1
	$(BASHTEST) `$(UNIQ) $(OBJDIR)win_parent_process2_mt_ppp.out | $(LINECOUNT)` -eq 22
	$(BASHTEST) `$(SORT) $(OBJDIR)win_parent_process2_mt_ppp.out | $(UNIQ) | $(LINECOUNT)` -eq 6
	$(BASHTEST) `$(UNIQ) $(OBJDIR)win_parent_process2_mt_ppp.out | $(GREP) "In grand_parent_tool PinTool is probed 1" | $(LINECOUNT)` -eq 1
	$(BASHTEST) `$(UNIQ) $(OBJDIR)win_parent_process2_mt_ppp.out | $(GREP) "In parent_tool PinTool is probed 1" | $(LINECOUNT)` -eq 3
	$(BASHTEST) `$(UNIQ) $(OBJDIR)win_parent_process2_mt_ppp.out | $(GREP) "In follow_child PinTool is probed 1" | $(LINECOUNT)` -eq 9
	$(BASHTEST) `$(UNIQ) $(OBJDIR)win_parent_process2_mt_ppp.out | $(GREP) "First Process was created successfully!" | $(LINECOUNT)` -eq 3
	$(BASHTEST) `$(UNIQ) $(OBJDIR)win_parent_process2_mt_ppp.out | $(GREP) "Second Process was created successfully!" | $(LINECOUNT)` -eq 3
	$(BASHTEST) `$(UNIQ) $(OBJDIR)win_parent_process2_mt_ppp.out | $(GREP) "Third Process was created successfully!" | $(LINECOUNT)` -eq 3
	$(RM) $(OBJDIR)win_parent_process2_mt_ppp.out

parent_process_waitpid_bug2.test: $(OBJDIR)parent_process_waitpid_bug2$(EXE_SUFFIX)
	$(PIN) -- $(OBJDIR)parent_process_waitpid_bug2$(EXE_SUFFIX)

# Logger tests

# Test that pintool.log is being overwritten on each run of pin In order to test that we run pin twice and 
# check that the log file contains only one "Hello from tool" line (i.e., the second run overwrote the log
# created by the first run, instead of appending to it)
tool_logger_overwrite.test: $(TESTAPP) $(OBJDIR)basic_tool$(PINTOOL_SUFFIX)
	$(PIN) -t $(OBJDIR)basic_tool$(PINTOOL_SUFFIX) -logfile $(OBJDIR)tool_logger_overwrite.log -- $(TESTAPP) makefile $(OBJDIR)tool_logger_overwrite.makefile.copy
	#  run again and make sure there isd only 1 "Hello from tool" (i.e., file was overwritten, not appended)
	$(PIN) -t $(OBJDIR)basic_tool$(PINTOOL_SUFFIX) -logfile $(OBJDIR)tool_logger_overwrite.log -- $(TESTAPP) makefile $(OBJDIR)tool_logger_overwrite.makefile.copy
	$(BASHTEST) `$(CGREP) "Hello from tool" $(OBJDIR)tool_logger_overwrite.log` -eq "1"
	$(RM) $(OBJDIR)tool_logger_overwrite.log $(OBJDIR)tool_logger_overwrite.makefile.copy

# Test that Tool logs are not missing after fork when -unique_log is used

# Applicaiton does many consecutive forks (10 - paramater). Parent waits for each child to terminate before forking the next one.
# Each child does very little and exit. Pin doesn't follow child
# This tests that with -unique_logfile 1 each forked child process gets its own log file and no logs are lost.
# In order to do so, we check that there are 11 log files created (1 for parent and 10 for children)
# and that each child log file has the expected line written by the tool after fork in child
tool_log_with_many_forks.test: $(OBJDIR)many_forks_app$(EXE_SUFFIX) $(OBJDIR)simple_fork_tool$(PINTOOL_SUFFIX)
	$(PIN) -unique_logfile -t $(OBJDIR)simple_fork_tool$(PINTOOL_SUFFIX) -sanity -unique_logfile -logfile $(OBJDIR)tool_log_with_many_forks.log -- $(OBJDIR)many_forks_app$(EXE_SUFFIX) 10 > $(OBJDIR)tool_log_with_many_forks.out 2>&1
	# make sure that there are 11 new log files created - tool_log_with_many_forks.log.pid (one per forked child)
	$(BASHTEST) `ls $(OBJDIR)tool_log_with_many_forks.log.* | $(LINECOUNT)` -eq 11
	# make sure each one has the "AfterForkInChild:  hello from".. line (except the parent so must equal to 10)
	@count=0; \
	for f in `ls $(OBJDIR)tool_log_with_many_forks.log.*`; do \
	  if $(QGREP) "AfterForkInChild:  hello from" $$f; then \
	  	count=$$((count + 1)); \
	  fi; \
	done; \
	echo "Found $$count files with the line"; \
	if [ $$count -ne 10 ]; then \
	    echo "Error: expected 10, got $$count" >&2; \
	    exit 1; \
	fi
	$(RM) $(OBJDIR)tool_log_with_many_forks.out $(OBJDIR)tool_log_with_many_forks.log*


# Many consecutive forks (parent wait for each child to end before doing the next fork). 
# Each child process execv application that prints and exit. Pin does follow child (-follow-execv enabled)
# This tests that with -unique_logfile 1 each forked child process gets its own log file and no logs are lost.
# In order to do so, we check that there are 4 log files created (1 for parent and 3 for children)
# and that each child log file has the expected line written by the tool after fork in child
tool_log_with_many_forks_and_execv.test: $(OBJDIR)many_forks_app$(EXE_SUFFIX) $(OBJDIR)child_process$(EXE_SUFFIX) $(OBJDIR)simple_fork_tool$(PINTOOL_SUFFIX)
	$(PIN) -unique_logfile -follow-execv -t $(OBJDIR)simple_fork_tool$(PINTOOL_SUFFIX) -sanity -unique_logfile -logfile $(OBJDIR)tool_log_with_many_forks_and_execv.log \
	-- $(OBJDIR)many_forks_app$(EXE_SUFFIX) 3 $(OBJDIR)child_process$(EXE_SUFFIX) > $(OBJDIR)tool_log_with_many_forks_and_execv.out 2>&1
	# make sure that there are 4 new log files created - tool_log_with_many_forks_and_execv.log.pid (one per forked child and 1 for the parent)
	$(BASHTEST) `ls $(OBJDIR)tool_log_with_many_forks_and_execv.log.* | $(LINECOUNT)` -eq 4
	# make sure each one has the "AfterForkInChild:  hello from".. line (except the parent so must equal to 3)
	@afterForkcount=0; \
	helloCount=0; \
	for f in $(OBJDIR)/tool_log_with_many_forks_and_execv.log.*; do \
	  if $(QGREP) -q "AfterForkInChild:  hello from" $$f; then \
	    afterForkcount=$$((afterForkcount + 1)); \
	  fi; \
	  if $(QGREP) -q "Hello from tool" $$f; then \
	    helloCount=$$((helloCount + 1)); \
	  fi; \
	done; \
	echo "Found $$afterForkcount files with 'AfterForkInChild:  hello from' line"; \
	echo "Found $$helloCount files with 'Hello from tool' line"; \
	# if afterForkcount is not 3 or hello count is not 4 then error \
	if [ $$afterForkcount -ne 3 ] || [ "$$helloCount" -ne 4 ]; then \
	  echo "Error: expected 3, got $$afterForkcount" >&2; \
	  exit 1; \
	fi
	$(RM) $(OBJDIR)tool_log_with_many_forks_and_execv.log* $(OBJDIR)tool_log_with_many_forks_and_execv.out	

##############################################################
#
# Build rules
#
##############################################################

# This section contains the build rules for all binaries that have special build rules.
# See makefile.default.rules for the default build rules.

###### Special tools' build rules ######

$(OBJDIR)unix_parent_tool$(PINTOOL_SUFFIX): $(OBJDIR)unix_parent_tool$(OBJ_SUFFIX) $(OBJDIR)arglist$(OBJ_SUFFIX)
	$(LINKER) $(TOOL_LDFLAGS) $(LINK_EXE)$@ $^ $(TOOL_LPATHS) $(TOOL_LIBS)

###### Special applications' build rules ######

$(OBJDIR)fork_app_static$(EXE_SUFFIX): fork_app.c
	$(APP_CC) $(APP_CFLAGS) $(DBG_INFO_CXX_ALWAYS) $(COMP_EXE)$@ $< $(APP_LDFLAGS) $(STATIC) $(APP_LIBS) $(DBG_INFO_LD_ALWAYS)

$(OBJDIR)vfork_app_static$(EXE_SUFFIX): vfork_app.c
	$(APP_CC) $(APP_CFLAGS) $(DBG_INFO_CXX_ALWAYS) $(COMP_EXE)$@ $< $(APP_LDFLAGS) $(STATIC) $(APP_LIBS) $(DBG_INFO_LD_ALWAYS)

$(OBJDIR)win_parent_process$(EXE_SUFFIX): win_parent_process.cpp
	$(APP_CXX) $(APP_CXXFLAGS) $(COMP_EXE)$@ $< $(APP_LDFLAGS) $(APP_LIBS) Advapi32.lib

$(OBJDIR)win_parent_process_mt$(EXE_SUFFIX): win_parent_process_mt.cpp
	$(APP_CXX) $(APP_CXXFLAGS) $(COMP_EXE)$@ $< $(APP_LDFLAGS) $(APP_LIBS) Advapi32.lib

$(OBJDIR)win_parent_process_unicode$(EXE_SUFFIX): win_parent_process_unicode.cpp
	$(APP_CXX) $(APP_CXXFLAGS) $(COMP_EXE)$@ $< $(APP_LDFLAGS) $(APP_LIBS) Advapi32.lib

$(OBJDIR)win_early_termination$(EXE_SUFFIX): win_early_termination.cpp $(OBJDIR)$(DLL_PREFIX)win_terminate_process_dll$(DLL_SUFFIX)
	$(APP_CXX) $(APP_CXXFLAGS) $(COMP_EXE)$@ $< $(APP_LDFLAGS) $(APP_LIBS) Advapi32.lib Dbghelp.lib $(OBJDIR)$(DLL_PREFIX)win_terminate_process_dll$(LIB_SUFFIX)

$(OBJDIR)fork_hang_app$(EXE_SUFFIX): fork_hang_app.cpp $(THREADLIB)
	$(APP_CXX) $(COMPONENT_INCLUDES) $(APP_CXXFLAGS) $(COMP_EXE)$@ $^ $(APP_LDFLAGS) $(APP_LPATHS) $(APP_LIBS) $(CXX_LPATHS) $(CXX_LIBS)

###### Special objects' build rules ######

$(OBJDIR)unix_parent_tool$(OBJ_SUFFIX): unix_parent_tool.cpp arglist.h
	$(CXX) $(TOOL_CXXFLAGS) $(COMP_OBJ)$@ $<

$(OBJDIR)arglist$(OBJ_SUFFIX): arglist.cpp arglist.h
	$(CXX) $(TOOL_CXXFLAGS) $(COMP_OBJ)$@ $<

###### Special dlls' build rules ######

$(OBJDIR)$(DLL_PREFIX)win_terminate_process_dll$(DLL_SUFFIX): win_terminate_process_dll.cpp
	$(APP_CXX) $(APP_CXXFLAGS) $(DLL_CXXFLAGS) $(COMP_EXE)$@ $< $(APP_LDFLAGS) $(DLL_LDFLAGS) $(APP_LIBS)

$(OBJDIR)rpc_plugin$(DLL_SUFFIX): rpc_plugin.cpp
	$(APP_CXX) $(RPC_PLUGIN_CXXFLAGS) $(DLL_CXXFLAGS) $(COMP_EXE)$@ $< $(APP_LDFLAGS) $(DLL_LDFLAGS) $(APP_LIBS)
	# Copy test plugin to the pind plugin directory
	$(CP) $(OBJDIR)rpc_plugin$(DLL_SUFFIX) $(PIN_ROOT)/$(TARGET)/pinrt/bin/plugins/
